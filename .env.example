# Kalshi demo endpoint (default). Change to production URL once you're ready.
KALSHI_API_URL=https://demo-api.kalshi.co/trade-api/v2

# Kalshi API credentials (demo).  See https://kalshi.com/docs for RSA key setup.
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=

# Optional: Claude veto filter.  Leave blank to disable the veto (fail-open).
ANTHROPIC_API_KEY=

# Optional: Telegram notifications.  No-op when blank.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# HALTED by default. Flip to true only once you've watched a few dry-run cycles
# and are happy with what the bot wants to do.
LIVE_TRADING_ENABLED=false

# Optional: disable the one-shot Claude veto per candidate trade.
CLAUDE_VETO_ENABLED=true
